{
    "name": "arikajs-monorepo",
    "private": true,
    "description": "A Modern, Elegant Web Framework for Node.js",
    "packageManager": "npm@10.9.2",
    "scripts": {
        "build": "npx turbo build",
        "test": "turbo test",
        "lint": "turbo lint",
        "clean": "turbo clean && rm -rf packages/*/dist packages/*/node_modules node_modules",
        "test:all": "./scripts/test-all.sh",
        "change": "changeset",
        "version-packages": "changeset version",
        "release": "npm run build && changeset publish"
    },
    "workspaces": [
        "packages/*"
    ],
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "pnpm": "^10.30.3",
        "turbo": "^2.8.13",
        "typescript": "^5.9.3"
    }
}